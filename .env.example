# ============================================================
# GESTÃO DE TERCEIROS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA suba o arquivo .env para o repositório!
# ============================================================

# ─── Banco de Dados PostgreSQL ──────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/gestao_terceiros"

# Ative SSL se o banco exigir (CapRover/Hetzner: true)
DB_SSL="true"

# ─── JWT (Autenticação) ──────────────────────────────────────
# Gere um segredo forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="TROQUE_POR_UMA_STRING_ALEATORIA_DE_64_CARACTERES"

# ─── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# URL completa onde o sistema está publicado (sem barra final)
APP_URL="https://terceiros.seudominio.com.br"

# ─── E-mail (SMTP para convites e alertas) ───────────────────
SMTP_HOST="smtp.seuservidor.com.br"
SMTP_PORT="587"
SMTP_USER="sistema@seudominio.com.br"
SMTP_PASS="SUA_SENHA_SMTP"

# ─── Admin Inicial (criado automaticamente no 1º start) ──────
# Após o primeiro login, altere a senha imediatamente!
ADMIN_EMAIL="admin@suaempresa.com.br"
ADMIN_PASSWORD="TroqueEstaSenha@2025!"
ADMIN_NAME="Administrador Master"
